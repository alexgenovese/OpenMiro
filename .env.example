# Bifrost or standard OpenAI compatible endpoint
OPENAI_BASE_URL="https://api.regolo.ai/v1"
# OPENAI_BASE_URL="http://localhost:11434/v1" # Per Ollama diretto

# The model name you configured in Bifrost / Ollama / OpenAI
OPENAI_MODEL_NAME="qwen3.5-9b"

# The API Key (can be dummy for Bifrost/Ollama, must be real for actual OpenAI/xAI)
OPENAI_API_KEY="your_api_key_here"

# Hindsight Vector/Graph Memory URL
HINDSIGHT_URL="http://localhost:8888"

# OpenSpace self-evolving skills engine
# Install: pip install "openspace @ git+https://github.com/HKUDS/OpenSpace.git"
# Skills and execution logs are stored locally in ./data/openspace/
# OPENSPACE_MODEL is set automatically at runtime from OPENAI_MODEL_NAME
# Leave these blank — they are resolved dynamically by main.py from the vars above.
OPENSPACE_API_KEY=""   # Optional: cloud community key from open-space.cloud
